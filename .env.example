# Supabase Auth (cliente + confirmación de email)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# En Supabase → Authentication → URL Configuration agregar Redirect URL:
#   http://localhost:3000/auth/callback
#   https://margify.app/auth/callback

# Número de WhatsApp de contacto (solo dígitos, código país sin +). Ej. Argentina: 5491155555555
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Dodo Payments (solo servidor) — suscripciones Pro/Scale
DODO_PAYMENTS_API_KEY=
# Webhook signing key (Developer → Webhooks → endpoint https://margify.app/api/webhooks/dodo)
DODO_PAYMENTS_WEBHOOK_KEY=
# Opcional: test_mode | live_mode (default live_mode)
# DODO_PAYMENTS_ENV=

# Supabase service role (webhooks Dodo → user_metadata billing, integraciones, alertas)
SUPABASE_SERVICE_ROLE_KEY=

# Cron (Vercel): Authorization Bearer CRON_SECRET en /api/cron/*
CRON_SECRET=

# Alertas por email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Margify <alertas@margify.app>

# Alertas WhatsApp (Meta Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Plantilla aprobada en Meta Business → WhatsApp → Plantillas de mensajes
# Nombre sugerido: margify_alert | Idioma: es
# Texto del cuerpo: Alerta de Margify: *{{1}}*. {{2}} Revisá tu dashboard.
WHATSAPP_ALERT_TEMPLATE_NAME=margify_alert
WHATSAPP_ALERT_TEMPLATE_LANG=es

# Margify AI Advisor (Claude) — recomendaciones en dashboard
ANTHROPIC_API_KEY=
# Opcional (default claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=

# TikTok Marketing API — OAuth + campañas
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# Redirect URI en TikTok: {origin}/api/auth/tiktok/callback
# TIKTOK_REDIRECT_URI=
# Opcional: modelo OpenAI (default gpt-4o-mini)
OPENAI_MODEL=

# Meta Ads — OAuth por usuario (App en developers.facebook.com)
# Redirect URIs a cargar en la app de Meta → Facebook Login for Business:
#   http://localhost:3000/api/auth/meta/callback   (dev)
#   https://margify.app/api/auth/meta/callback     (prod)
META_APP_ID=
META_APP_SECRET=
# Opcional: override del redirect URI (si no, se arma con NEXT_PUBLIC_SITE_URL)
# META_REDIRECT_URI=

# Meta (modo legacy / admin) — token fijo de servidor para GET /api/meta/status
# Se mantiene por compatibilidad, pero la vinculación real es por OAuth (META_APP_ID/SECRET).
META_ACCESS_TOKEN=

# Mercado Libre OAuth (solo servidor). En producción: NEXT_PUBLIC_SITE_URL=https://margify.app
# Redirect URI en la app de ML: {origin}/api/auth/mercadolibre/callback
NEXT_PUBLIC_SITE_URL=
MERCADOLIBRE_APP_ID=
MERCADOLIBRE_CLIENT_SECRET=
# Opcional (default https://auth.mercadolibre.com.ar)
# MERCADOLIBRE_AUTH_BASE=

# Shopify — OAuth por tienda (app creada en Shopify Partners / dev dashboard)
# Redirect URIs a cargar en la app de Shopify → Allowed redirection URL(s):
#   http://localhost:3000/api/auth/shopify/callback   (dev)
#   https://margify.app/api/auth/shopify/callback     (prod)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Scopes separados por coma, SIN espacios. Ver https://shopify.dev/docs/api/usage/access-scopes
SHOPIFY_SCOPES=read_products,read_orders,read_all_orders,read_customers,read_inventory,read_analytics,read_reports,read_price_rules,read_discounts,read_marketing_events,read_locations
# Redirect URI exacto que cargaste en la app. En prod usar https://margify.app/api/auth/shopify/callback
SHOPIFY_REDIRECT_URI=

# TiendaNube (Nuvemshop) — OAuth por tienda (app en Partner Portal)
# Redirect URL en el portal: {origin}/api/auth/tiendanube/callback
TIENDANUBE_APP_ID=
TIENDANUBE_CLIENT_SECRET=
TIENDANUBE_REDIRECT_URI=
TIENDANUBE_USER_AGENT=

# Google Ads API (solo servidor)
# Redirect URI que también tenés que cargar en Google Cloud Console → OAuth Client:
#   http://localhost:3000/api/auth/google/callback       (dev)
#   https://margify.app/api/auth/google/callback          (prod)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=
# Opcional: si tu developer token está bajo una cuenta MCC, cargá el ID del MCC (sin guiones).
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Opcional: forzar la customer_id que querés consultar (sin guiones). Si no, se detecta.
# GOOGLE_ADS_CUSTOMER_ID=
