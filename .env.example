# Número de WhatsApp de contacto (solo dígitos, código país sin +). Ej. Argentina: 5491155555555
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Margify AI (solo servidor — no usar NEXT_PUBLIC_)
OPENAI_API_KEY=
# Opcional: modelo OpenAI (default gpt-4o-mini)
OPENAI_MODEL=

# Meta / Facebook — token solo en .env.local (nunca subir a Git).
# GET /api/meta/status para comprobar que conecta (solo servidor).
META_ACCESS_TOKEN=

# Mercado Libre OAuth (solo servidor). En producción: NEXT_PUBLIC_SITE_URL=https://margify.app
# Redirect URI en la app de ML: {origin}/api/auth/mercadolibre/callback
NEXT_PUBLIC_SITE_URL=
MERCADOLIBRE_APP_ID=
MERCADOLIBRE_CLIENT_SECRET=
# Opcional (default https://auth.mercadolibre.com.ar)
# MERCADOLIBRE_AUTH_BASE=
