# Número de WhatsApp de contacto (solo dígitos, código país sin +). Ej. Argentina: 5491155555555
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Margify AI (solo servidor — no usar NEXT_PUBLIC_)
OPENAI_API_KEY=
# Opcional: modelo OpenAI (default gpt-4o-mini)
OPENAI_MODEL=

# Meta Ads — OAuth por usuario (App en developers.facebook.com)
# Redirect URIs a cargar en la app de Meta → Facebook Login for Business:
#   http://localhost:3000/api/auth/meta/callback   (dev)
#   https://margify.app/api/auth/meta/callback     (prod)
META_APP_ID=
META_APP_SECRET=
# Opcional: override del redirect URI (si no, se arma con NEXT_PUBLIC_SITE_URL)
# META_REDIRECT_URI=

# Meta (modo legacy / admin) — token fijo de servidor para GET /api/meta/status
# Se mantiene por compatibilidad, pero la vinculación real es por OAuth (META_APP_ID/SECRET).
META_ACCESS_TOKEN=

# Mercado Libre OAuth (solo servidor). En producción: NEXT_PUBLIC_SITE_URL=https://margify.app
# Redirect URI en la app de ML: {origin}/api/auth/mercadolibre/callback
NEXT_PUBLIC_SITE_URL=
MERCADOLIBRE_APP_ID=
MERCADOLIBRE_CLIENT_SECRET=
# Opcional (default https://auth.mercadolibre.com.ar)
# MERCADOLIBRE_AUTH_BASE=

# Shopify — OAuth por tienda (app creada en Shopify Partners / dev dashboard)
# Redirect URIs a cargar en la app de Shopify → Allowed redirection URL(s):
#   http://localhost:3000/api/auth/shopify/callback   (dev)
#   https://margify.app/api/auth/shopify/callback     (prod)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Scopes separados por coma, SIN espacios. Ver https://shopify.dev/docs/api/usage/access-scopes
SHOPIFY_SCOPES=read_products,read_orders,read_all_orders,read_customers,read_inventory,read_analytics,read_reports,read_price_rules,read_discounts,read_marketing_events,read_locations
# Redirect URI exacto que cargaste en la app. En prod usar https://margify.app/api/auth/shopify/callback
SHOPIFY_REDIRECT_URI=

# Google Ads API (solo servidor)
# Redirect URI que también tenés que cargar en Google Cloud Console → OAuth Client:
#   http://localhost:3000/api/auth/google/callback       (dev)
#   https://margify.app/api/auth/google/callback          (prod)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=
# Opcional: si tu developer token está bajo una cuenta MCC, cargá el ID del MCC (sin guiones).
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Opcional: forzar la customer_id que querés consultar (sin guiones). Si no, se detecta.
# GOOGLE_ADS_CUSTOMER_ID=
